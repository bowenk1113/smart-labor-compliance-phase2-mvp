DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=infini_rag_flow
DB_NAME=employment
DB_BACKEND=sqlite
SQLITE_PATH=storage/slc_phase2.db
SERVE_FRONTEND=false
FRONTEND_DIST_PATH=../frontend/dist

MILVUS_URI=http://127.0.0.1:19530
EMBEDDING_MODEL_PATH=../knowforge-rag-platform/models/bge-m3
RERANKER_MODEL_PATH=../knowforge-rag-platform/models/bge-reranker-large
BERT_CLASSIFIER_PATH=../knowforge-rag-platform/models/bert_query_classifier

DIFY_API_KEY=
DIFY_BASE_URL=http://127.0.0.1/v1

# RAG 生成层配置：
# auto：有 Dify Key 先用 Dify；否则有 PHASE2_LLM_API_KEY 就用 OpenAI-compatible；都没有则模板兜底。
# dify：强制普通 /api/chat 在文档 RAG 命中后调用 Dify。
# openai_compatible：强制调用兼容 OpenAI Chat Completions 的大模型网关。
# template：只使用模板兜底，不调用大模型。
PHASE2_GENERATION_BACKEND=auto
PHASE2_LLM_BASE_URL=https://api.openai.com/v1
PHASE2_LLM_API_KEY=
PHASE2_LLM_MODEL=gpt-4o-mini
PHASE2_LLM_TEMPERATURE=0.2
PHASE2_LLM_TIMEOUT_SECONDS=30

# 查询规划 LLM 配置：
# PHASE2_QUERY_LLM_ENABLED=false 表示默认不调用大模型生成查询变体，方便离线演示。
# 改成 true 且填写 PHASE2_LLM_API_KEY 后，系统会调用同一个 OpenAI-compatible 网关生成 rewritten_query、variants 和 query_type。
# PHASE2_QUERY_LLM_BACKEND 预留后端类型；MVP 当前支持 openai_compatible。
# PHASE2_QUERY_LLM_MAX_VARIANTS 控制混合检索最多使用多少个查询变体。
# PHASE2_QUERY_LLM_TEMPERATURE 建议保持较低，避免查询规划发散。
PHASE2_QUERY_LLM_ENABLED=false
PHASE2_QUERY_LLM_BACKEND=openai_compatible
PHASE2_QUERY_LLM_MAX_VARIANTS=4
PHASE2_QUERY_LLM_TEMPERATURE=0.1
